<odoo>
    <record id="view_promocion_kanban" model="ir.ui.view">
        <field name="name">zapatos.promocion.kanban</field>
        <field name="model">zapatos.promocion</field>
        <field name="arch" type="xml">
            <kanban default_group_by="nivel_oferta">
                <field name="color"/>
                <field name="name"/>
                <field name="codigo_promo"/>
                <field name="porcentaje_descuento"/>
                <field name="precio_final"/>
                <field name="validez"/>
                <field name="imagen"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click oe_kanban_color_#{kanban_getcolor(record.color.raw_value)}">
                            <div class="o_kanban_image">
                                <img t-att-src="kanban_image('zapatos.promocion', 'imagen', record.id.raw_value)" alt="Promocion" class="o_image_64_contain"/>
                            </div>
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                                <div class="text-muted">
                                    <field name="codigo_promo"/>
                                </div>
                                <div>
                                    Descuento: <field name="porcentaje_descuento"/> %
                                </div>
                                <div>
                                    Precio final: <field name="precio_final"/>
                                </div>
                                <div>
                                    <field name="validez" widget="label_selection" options="{'classes': {'valida': 'success', 'no_valida': 'danger'}}"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_promocion_list" model="ir.ui.view">
        <field name="name">zapatos.promocion.list</field>
        <field name="model">zapatos.promocion</field>
        <field name="arch" type="xml">
            <list decoration-success="validez == 'valida'" decoration-danger="validez == 'no_valida'">
                <field name="codigo_promo"/>
                <field name="name"/>
                <field name="zapato_id"/>
                <field name="porcentaje_descuento"/>
                <field name="precio_original"/>
                <field name="precio_final"/>
                <field name="ahorro"/>
                <field name="fecha_inicio"/>
                <field name="fecha_fin"/>
                <field name="nivel_oferta" widget="badge" decoration-info="nivel_oferta == 'bajo'" decoration-warning="nivel_oferta == 'medio'" decoration-danger="nivel_oferta == 'alto'"/>
                <field name="validez" widget="badge" decoration-success="validez == 'valida'" decoration-danger="validez == 'no_valida'"/>
            </list>
        </field>
    </record>

    <record id="view_promocion_form" model="ir.ui.view">
        <field name="name">zapatos.promocion.form</field>
        <field name="model">zapatos.promocion</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="validez" widget="statusbar" statusbar_visible="valida,no_valida"/>
                </header>
                <sheet>
                    <field name="imagen" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <label for="codigo_promo" string="Codigo"/>
                        <h2>
                            <field name="codigo_promo"/>
                        </h2>
                        <h1>
                            <field name="name" placeholder="Nombre de la promocion"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Datos generales">
                            <field name="zapato_id"/>
                            <field name="nivel_oferta"/>
                            <field name="color" widget="color_picker"/>
                            <field name="validez" widget="badge" decoration-success="validez == 'valida'" decoration-danger="validez == 'no_valida'"/>
                        </group>
                        <group string="Condiciones de la oferta">
                            <field name="porcentaje_descuento"/>
                            <field name="precio_original"/>
                            <field name="precio_final"/>
                            <field name="ahorro"/>
                            <field name="unidades_disponibles"/>
                            <field name="fecha_inicio"/>
                            <field name="fecha_fin"/>
                        </group>
                    </group>
                    <group string="Descripcion">
                        <field name="descripcion" nolabel="1" placeholder="Detalle de la promocion"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_promocion_search" model="ir.ui.view">
        <field name="name">zapatos.promocion.search</field>
        <field name="model">zapatos.promocion</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="codigo_promo"/>
                <field name="zapato_id"/>
                <filter name="filtro_valida" string="Validas" domain="[('validez', '=', 'valida')]"/>
                <filter name="filtro_no_valida" string="No validas" domain="[('validez', '=', 'no_valida')]"/>
                <group expand="0" string="Agrupar por">
                    <filter name="group_nivel" string="Nivel de oferta" context="{'group_by': 'nivel_oferta'}"/>
                    <filter name="group_validez" string="Validez" context="{'group_by': 'validez'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_promocion" model="ir.actions.act_window">
        <field name="name">Promociones</field>
        <field name="res_model">zapatos.promocion</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

    <menuitem id="menu_zapatos_promociones"
              name="Promociones"
              parent="zapatos.menu_zapatos_root"
              action="action_promocion"
              sequence="20"/>
</odoo>
