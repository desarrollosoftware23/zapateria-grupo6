<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_zapato_form_inherit_proveedor_categoria" model="ir.ui.view">
        <field name="name">zapatos.form.inherit.proveedor.categoria</field>
        <field name="model">zapatos.zapato</field>
        <field name="inherit_id" ref="zapatos.view_zapato_form"/>
        <field name="arch" type="xml">

            <xpath expr="//sheet/group" position="after">

                <separator string="Información Comercial"/>

                <group col="2">
                    <field name="proveedor_id"
                           placeholder="Seleccione un proveedor"/>
                    <field name="categoria_id"
                           placeholder="Seleccione una categoría"/>
                </group>

            </xpath>

        </field>
    </record>

</odoo>