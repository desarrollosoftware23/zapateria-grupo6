<odoo>

    <record id="from_zapatos_stock" model="ir.ui.view">
        <field name="name">from_zapato_stock</field>
        <field name="model">zapatos.zapato</field>
        <field name="inherit_id" ref="zapatos.view_zapato_form"/>
        <field name="arch" type="xml">

            <xpath expr="//group" position="inside">
                <field name="estado_stock" readonly="1"/>
            </xpath>

            <xpath expr="//sheet" position="inside">
                <div class="alert alert-warning"
                    role="alert"
                    invisible="estado_stock != 'amarillo'">
                    Stock bajo: Revisar inventario
                </div>
            </xpath>

        </field>
    </record>
 
    <record id="view_zapato_list_extension" model="ir.ui.view">
        <field name="name">zapatos.zapato.list.extension</field>
        <field name="model">zapatos.zapato</field>
        <field name="inherit_id" ref="zapatos.view_zapato_list"/>
        <field name="arch" type="xml">

            <xpath expr="//list" position="attributes">
                <attribute name="decoration-danger">estado_stock == 'rojo'</attribute>
                <attribute name="decoration-warning">estado_stock == 'amarillo'</attribute>
                <attribute name="decoration-success">estado_stock == 'verde'</attribute>
            </xpath>

            <xpath expr="//list" position="inside">
                <field name="estado_stock" readonly="1"/>
            </xpath>

        </field>
    </record> 

</odoo>